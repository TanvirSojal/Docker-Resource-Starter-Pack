# ==========================================
# 1. n8n HOST AND URL CONFIGURATION
# ==========================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=UTC

# ==========================================
# 2. DATABASE CONNECTION (For n8n)
# ==========================================
# If using the 'local-db' profile, this points to 'postgres' and port '5435'
# If using your existing standard DB, change host to its IP and port to '5432'
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5435
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=n8n_secure_password_here

# ==========================================
# 3. LOCAL POSTGRES CREATION (Optional)
# ==========================================
# ONLY used if you spin up the container via 'docker compose --profile local-db up -d'
# Defines the custom port to avoid conflicts with standard host Postgres instances
LOCAL_POSTGRES_PORT=5435
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_password_here

# ==========================================
# 4. n8n BASIC AUTHENTICATION
# ==========================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
